# -------------------------------------------------------------------------
# SpeakRight - Comprehensive Git Ignore
# -------------------------------------------------------------------------

# Miscellaneous / OS files
*.class
*.log
*.pyc
*.swp
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
.history
.svn/
migrate_working_dir/

# IDE / Editor Files
.idea/
*.iml
*.ipr
*.iws
.vscode/
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Secrets / Environment files
.env
.env.*
*.env
*.keystore
*.jks
*.p12
*.pem
*.developerprofile
key.properties
signing-key.password

# Flutter / Dart / Pub related
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
bin/
doc/api/
lib/generated/
/coverage/

# Android-specific exclusions
/android/local.properties
/android/key.properties
/android/.gradle/
/android/app/build/
/android/build/
/android/app/debug/
/android/app/profile/
/android/app/release/

# iOS/macOS-specific exclusions
/ios/Flutter/Generated.xcconfig
/ios/Flutter/flutter_export_environment.sh
/ios/Pods/
/ios/.symlinks/
/ios/Flutter/App.framework
/ios/Flutter/Flutter.framework
/ios/Flutter/Flutter.podspec
/ios/Runner/GeneratedPluginRegistrant.h
/ios/Runner/GeneratedPluginRegistrant.m
/macos/Flutter/ephemeral/

# Web-specific exclusions
/web/flutter_bootstrap.js

# On-Device ML Models (Avoid committing large weights to git)
*.onnx
*.bin
*.gguf
*.tflite
/assets/models/
